# ==============================================
# 加密貨幣 AI 量化交易機器人 配置檔案
# ==============================================

# ── Gemini AI (可選，不填則用純規則模式) ──
# 免費取得: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here
# 可選模型: gemini-1.5-flash (快/便宜) | gemini-1.5-pro (強/貴)
GEMINI_MODEL=gemini-1.5-flash

# ── 交易所設定 ──
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_API_SECRET=your_exchange_api_secret_here
TESTNET=true

# ── 交易模式 ──
PAPER_TRADING=true
PAPER_BALANCE=10000

# ── 交易對 ──
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# ── 時間框架 ──
PRIMARY_TIMEFRAME=1h

# ── 風險設定 ──
RISK_PER_TRADE=1.0
MAX_POSITIONS=3
MAX_DAILY_LOSS=3.0
MAX_DRAWDOWN=10.0
MIN_RISK_REWARD=1.5

# ── AI 信號門檻 ──
MIN_CONFIDENCE=65

# ── 掃描間隔 (秒) ──
SCAN_INTERVAL=60

# ── Telegram 通知 (可選) ──
# 1. 找 @BotFather 建立 bot，取得 token
# 2. 找 @userinfobot 取得你的 chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# 網頁儀表板 port
DASHBOARD_PORT=8080
